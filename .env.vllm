ASR_SUMMARY_VLLM_IMAGE=vllm/vllm-openai:latest

WHISPER_COMPUTE_TYPE=float16

SLLM_PROVIDER=vllm
SLLM_BASE_URL=http://sllm-vllm:8000
SLLM_MODEL=ax-4-light
SLLM_TIMEOUT_SEC=180
SLLM_MAX_TOKENS=512
SLLM_MAX_PROMPT_CHARS=16000
SLLM_TEMPERATURE=0.1
SLLM_TOP_P=0.9
SLLM_REQUEST_PATH=/v1/chat/completions
SLLM_USE_CHAT_ENDPOINT=true

SLLM_VLLM_MODEL=skt/A.X-4.0-Light
SLLM_SERVED_MODEL_NAME=ax-4-light
SLLM_VLLM_HOST_MODELS=./models
VLLM_TENSOR_PARALLEL_SIZE=1
VLLM_GPU_DEVICE=0
VLLM_GPU_MEMORY_UTILIZATION=0.92
VLLM_MAX_MODEL_LEN=16384
